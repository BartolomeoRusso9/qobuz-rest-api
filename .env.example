# ─── Qobuz Local API - Configuration ───
# Copy this file as .env and fill in the values

# Qobuz App ID and Secret 
# (If left empty, the API will automatically extract them from play.qobuz.com on startup)
QOBUZ_APP_ID=
QOBUZ_SECRET=

# Mode 1: User Token (Recommended, this is all you need)
# Find it in localStorage on https://play.qobuz.com/
# key: "localuser.token"
QOBUZ_TOKEN=

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
