# ─── Qobuz Local API - Configuration ───
# Copy this file as .env and fill in the values

# Qobuz App ID and Secret
QOBUZ_APP_ID=
QOBUZ_SECRET=

# Find it in localStorage on https://play.qobuz.com/
# key: "localuser.token"
QOBUZ_TOKEN=

# ─── API security ───
# Strongly recommended if the port is reachable from anything other than
# localhost. When set, every request (except "/", "/docs", "/openapi.json",
# "/redoc") must include the header:  X-API-Key: <value>
# Generate one with: openssl rand -hex 32
API_KEY=

# Comma-separated list of allowed browser origins for CORS.
# Leave empty to disable cross-origin browser access entirely (recommended
# unless you're calling this API directly from a web page on another origin).
# Example: CORS_ORIGINS=http://localhost:3000,https://myapp.example.com
CORS_ORIGINS=

# Root directory that all download output_dir paths are confined to.
# Requests that try to escape this directory (e.g. via "../") are rejected.
DOWNLOAD_ROOT=./downloads

# Log level: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Optional: override base Qobuz API endpoint.
# Use this only if the API path changes or you are using a custom proxy.
QOBUZ_API_BASE=https://www.qobuz.com/api.json/0.2

# Optional: use a residential proxy for Qobuz requests.
# Examples:
# QOBUZ_PROXY=http://user:pass@proxy.example.com:8080
# QOBUZ_PROXY=socks5://user:pass@proxy.example.com:1080
QOBUZ_PROXY=

# Optional: allow multiple Qobuz auth tokens as a JSON array or comma-separated list.
# Example:
# QOBUZ_AUTH_TOKENS=["token1","token2"]
# QOBUZ_AUTH_TOKENS=token1,token2
QOBUZ_AUTH_TOKENS=
